@model EcommerceApp.Models.CheckoutViewModel
@{
    ViewData["Title"] = "Checkout";
}

<div class="container py-4">
    <h1 class="fw-bold mb-4"><i class="fas fa-lock me-2 text-warning"></i>Checkout</h1>

    <div class="row g-4">
        <div class="col-lg-7">
            <form asp-action="PlaceOrder" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-body">
                        <h5 class="fw-bold mb-3">Shipping Information</h5>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="FirstName" class="form-label"></label>
                                <input asp-for="FirstName" class="form-control" />
                                <span asp-validation-for="FirstName" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="LastName" class="form-label"></label>
                                <input asp-for="LastName" class="form-control" />
                                <span asp-validation-for="LastName" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Email" class="form-label"></label>
                                <input asp-for="Email" class="form-control" />
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Phone" class="form-label"></label>
                                <input asp-for="Phone" class="form-control" />
                            </div>
                            <div class="col-12">
                                <label asp-for="Address" class="form-label"></label>
                                <input asp-for="Address" class="form-control" />
                                <span asp-validation-for="Address" class="text-danger small"></span>
                            </div>
                            <div class="col-md-5">
                                <label asp-for="City" class="form-label"></label>
                                <input asp-for="City" class="form-control" />
                            </div>
                            <div class="col-md-3">
                                <label asp-for="State" class="form-label"></label>
                                <input asp-for="State" class="form-control" />
                            </div>
                            <div class="col-md-4">
                                <label asp-for="ZipCode" class="form-label"></label>
                                <input asp-for="ZipCode" class="form-control" />
                            </div>
                            <div class="col-12">
                                <label asp-for="Country" class="form-label"></label>
                                <select asp-for="Country" class="form-select">
                                    <option value="US">United States</option>
                                    <option value="CA">Canada</option>
                                    <option value="GB">United Kingdom</option>
                                    <option value="IN">India</option>
                                    <option value="AU">Australia</option>
                                </select>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-body">
                        <h5 class="fw-bold mb-3">Payment (Demo)</h5>
                        <div class="alert alert-info small">
                            <i class="fas fa-info-circle me-1"></i>This is a demo. Integrate Stripe keys in appsettings.json for real payments.
                        </div>
                        <div class="row g-3">
                            <div class="col-12">
                                <label class="form-label">Card Number</label>
                                <input type="text" class="form-control" placeholder="4242 4242 4242 4242" />
                            </div>
                            <div class="col-6">
                                <label class="form-label">Expiry</label>
                                <input type="text" class="form-control" placeholder="12/28" />
                            </div>
                            <div class="col-6">
                                <label class="form-label">CVV</label>
                                <input type="text" class="form-control" placeholder="123" />
                            </div>
                        </div>
                    </div>
                </div>

                <div class="mb-4">
                    <label asp-for="Notes" class="form-label">Notes (Optional)</label>
                    <textarea asp-for="Notes" class="form-control" rows="2"></textarea>
                </div>

                <button type="submit" class="btn btn-warning btn-lg w-100 py-3 fw-bold">
                    <i class="fas fa-lock me-2"></i>Place Order
                </button>
            </form>
        </div>

        <div class="col-lg-5">
            <div class="card border-0 shadow-sm sticky-top" style="top:80px;">
                <div class="card-header bg-dark text-white fw-bold">Order Summary</div>
                <div class="card-body">
                    @if (Model.Cart != null)
                    {
                        @foreach (var item in Model.Cart.CartItems)
                        {
                            <div class="d-flex justify-content-between mb-2 small">
                                <span>@item.Product?.Name <span class="text-muted">×@item.Quantity</span></span>
                                <span>$@item.Subtotal.ToString("F2")</span>
                            </div>
                        }
                        <hr />
                        <div class="d-flex justify-content-between text-muted small mb-1">
                            <span>Subtotal</span><span>$@Model.Cart.Total.ToString("F2")</span>
                        </div>
                        <div class="d-flex justify-content-between text-muted small mb-1">
                            <span>Shipping</span>
                            <span>@(Model.Cart.Total >= 50 ? "FREE" : "$9.99")</span>
                        </div>
                        <div class="d-flex justify-content-between text-muted small mb-2">
                            <span>Tax (8%)</span><span>$@(Model.Cart.Total * 0.08m).ToString("F2")</span>
                        </div>
                        <hr />
                        <div class="d-flex justify-content-between fw-bold fs-5">
                            <span>Total</span>
                            <span class="text-warning">$@((Model.Cart.Total + (Model.Cart.Total >= 50 ? 0 : 9.99m) + Model.Cart.Total * 0.08m).ToString("F2"))</span>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
