@model EcommerceApp.Models.Cart
@{
    ViewData["Title"] = "Shopping Cart";
}

<div class="container py-4">
    <h1 class="fw-bold mb-4"><i class="fas fa-shopping-cart me-2 text-warning"></i>Shopping Cart</h1>

    @if (!Model.CartItems.Any())
    {
        <div class="text-center py-5">
            <i class="fas fa-shopping-cart fa-5x text-muted mb-4"></i>
            <h3 class="text-muted">Your cart is empty</h3>
            <p class="text-muted">Add some products to get started!</p>
            <a asp-controller="Products" asp-action="Index" class="btn btn-warning btn-lg mt-3 px-5">
                <i class="fas fa-arrow-left me-2"></i>Continue Shopping
            </a>
        </div>
    }
    else
    {
        <div class="row g-4">
            <!-- Cart Items -->
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm">
                    <div class="card-body p-0">
                        <table class="table table-borderless mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="py-3 ps-4">Product</th>
                                    <th class="py-3 text-center">Qty</th>
                                    <th class="py-3 text-end">Price</th>
                                    <th class="py-3 text-end">Subtotal</th>
                                    <th class="py-3"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.CartItems)
                                {
                                    <tr class="align-middle border-bottom">
                                        <td class="ps-4">
                                            <div class="d-flex align-items-center">
                                                <div class="bg-light rounded me-3 d-flex align-items-center justify-content-center" style="width:60px;height:60px;">
                                                    <i class="fas fa-image text-muted"></i>
                                                </div>
                                                <div>
                                                    <a asp-controller="Products" asp-action="Details" asp-route-id="@item.ProductId" class="fw-bold text-dark text-decoration-none">
                                                        @item.Product?.Name
                                                    </a>
                                                    <small class="d-block text-muted">@item.Product?.Category?.Name</small>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="text-center">
                                            <form asp-controller="Cart" asp-action="UpdateQuantity" method="post" class="d-inline-flex align-items-center gap-2">
                                                <input type="hidden" name="cartItemId" value="@item.Id" />
                                                <input type="number" name="quantity" value="@item.Quantity" min="1" max="99" class="form-control form-control-sm text-center" style="width:65px;" onchange="this.form.submit()" />
                                            </form>
                                        </td>
                                        <td class="text-end text-muted">$@item.Product?.Price.ToString("F2")</td>
                                        <td class="text-end fw-bold text-warning">$@item.Subtotal.ToString("F2")</td>
                                        <td>
                                            <form asp-controller="Cart" asp-action="Remove" method="post">
                                                <input type="hidden" name="cartItemId" value="@item.Id" />
                                                <button type="submit" class="btn btn-sm text-danger border-0 bg-transparent" title="Remove">
                                                    <i class="fas fa-trash"></i>
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="d-flex justify-content-between mt-3">
                    <a asp-controller="Products" asp-action="Index" class="btn btn-outline-dark">
                        <i class="fas fa-arrow-left me-2"></i>Continue Shopping
                    </a>
                    <form asp-controller="Cart" asp-action="Clear" method="post">
                        <button type="submit" class="btn btn-outline-danger">
                            <i class="fas fa-trash me-2"></i>Clear Cart
                        </button>
                    </form>
                </div>
            </div>

            <!-- Order Summary -->
            <div class="col-lg-4">
                <div class="card border-0 shadow-sm">
                    <div class="card-body">
                        <h5 class="fw-bold mb-4">Order Summary</h5>
                        <div class="d-flex justify-content-between mb-2">
                            <span>Subtotal (@Model.ItemCount items)</span>
                            <span>$@Model.Total.ToString("F2")</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span>Shipping</span>
                            <span class="text-success">@(Model.Total >= 50 ? "FREE" : "$9.99")</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span>Tax (8%)</span>
                            <span>$@(Model.Total * 0.08m).ToString("F2")</span>
                        </div>
                        <hr />
                        <div class="d-flex justify-content-between fw-bold fs-5 mb-4">
                            <span>Total</span>
                            <span class="text-warning">
                                $@((Model.Total + (Model.Total >= 50 ? 0 : 9.99m) + Model.Total * 0.08m).ToString("F2"))
                            </span>
                        </div>
                        <a asp-controller="Checkout" asp-action="Index" class="btn btn-warning btn-lg w-100 mb-3">
                            <i class="fas fa-lock me-2"></i>Secure Checkout
                        </a>
                        <div class="text-center">
                            <small class="text-muted"><i class="fas fa-shield-alt me-1"></i>SSL Encrypted & Secure</small>
                        </div>
                    </div>
                </div>

                @if (Model.Total < 50)
                {
                    <div class="alert alert-info mt-3">
                        <i class="fas fa-truck me-2"></i>
                        Add <strong>$@((50 - Model.Total).ToString("F2"))</strong> more for free shipping!
                    </div>
                }
            </div>
        </div>
    }
</div>
