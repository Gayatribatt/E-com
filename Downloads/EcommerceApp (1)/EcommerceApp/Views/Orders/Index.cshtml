@model IEnumerable<EcommerceApp.Models.Order>
@{
    ViewData["Title"] = "My Orders";
}

<div class="container py-4">
    <h1 class="fw-bold mb-4"><i class="fas fa-box me-2 text-warning"></i>My Orders</h1>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="fas fa-box-open fa-5x text-muted mb-4"></i>
            <h3 class="text-muted">No orders yet</h3>
            <a asp-controller="Products" asp-action="Index" class="btn btn-warning mt-3">Start Shopping</a>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var order in Model)
            {
                <div class="col-12">
                    <div class="card border-0 shadow-sm">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
                                <div>
                                    <h5 class="fw-bold mb-1">Order #@order.OrderNumber</h5>
                                    <small class="text-muted">Placed @order.OrderDate.ToString("MMMM dd, yyyy")</small>
                                </div>
                                <div class="d-flex align-items-center gap-3">
                                    <span class="badge @(order.Status == EcommerceApp.Models.OrderStatus.Delivered ? "bg-success" : order.Status == EcommerceApp.Models.OrderStatus.Shipped ? "bg-info" : order.Status == EcommerceApp.Models.OrderStatus.Cancelled ? "bg-danger" : "bg-warning text-dark") fs-6 px-3">
                                        @order.Status
                                    </span>
                                    <span class="fw-bold text-warning fs-5">$@order.Total.ToString("F2")</span>
                                    <a asp-action="Details" asp-route-id="@order.Id" class="btn btn-outline-dark btn-sm">Details</a>
                                </div>
                            </div>
                            <div class="mt-3 d-flex flex-wrap gap-2">
                                @foreach (var item in order.OrderItems)
                                {
                                    <span class="badge bg-light text-dark border">@item.Product?.Name ×@item.Quantity</span>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
