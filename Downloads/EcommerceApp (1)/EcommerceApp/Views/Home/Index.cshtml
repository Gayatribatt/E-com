@model EcommerceApp.Models.HomeViewModel
@{
    ViewData["Title"] = "Home - ShopWave";
}

<!-- Hero Banner -->
<section class="hero-section bg-dark text-white py-5 mb-5">
    <div class="container py-4">
        <div class="row align-items-center">
            <div class="col-lg-7">
                <span class="badge bg-warning text-dark mb-3 fs-6 px-3 py-2">New Season Arrivals</span>
                <h1 class="display-3 fw-bold mb-4">Shop Smarter, <span class="text-warning">Live Better</span></h1>
                <p class="lead text-muted mb-4">Discover thousands of products across all categories. Quality guaranteed, prices unbeatable.</p>
                <a asp-controller="Products" asp-action="Index" class="btn btn-warning btn-lg px-5 py-3 me-3">
                    <i class="fas fa-shopping-bag me-2"></i>Shop Now
                </a>
                <a asp-controller="Products" asp-action="Index" asp-route-categoryId="1" class="btn btn-outline-light btn-lg px-4 py-3">
                    Browse Electronics
                </a>
            </div>
            <div class="col-lg-5 text-center d-none d-lg-block">
                <div class="hero-image-placeholder rounded-3 d-flex align-items-center justify-content-center" style="height:350px; background: linear-gradient(135deg, #ffc107 0%, #ff8f00 100%); opacity: 0.9;">
                    <i class="fas fa-shopping-bag" style="font-size: 120px; color: rgba(255,255,255,0.3);"></i>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Categories -->
<section class="container mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">Shop by Category</h2>
        <a asp-controller="Products" asp-action="Index" class="text-warning text-decoration-none">View All <i class="fas fa-arrow-right ms-1"></i></a>
    </div>
    <div class="row g-3">
        @foreach (var cat in Model.Categories)
        {
            <div class="col-6 col-md-4 col-lg-2">
                <a asp-controller="Products" asp-action="Index" asp-route-categoryId="@cat.Id" class="text-decoration-none">
                    <div class="card text-center border-0 shadow-sm h-100 category-card hover-lift">
                        <div class="card-body py-4">
                            <div class="category-icon mb-3">
                                @{
                                    var icon = cat.Name switch {
                                        "Electronics" => "fa-laptop",
                                        "Clothing" => "fa-tshirt",
                                        "Books" => "fa-book",
                                        "Home & Garden" => "fa-home",
                                        "Sports" => "fa-running",
                                        _ => "fa-tag"
                                    };
                                }
                                <i class="fas @icon fa-2x text-warning"></i>
                            </div>
                            <h6 class="card-title fw-bold text-dark">@cat.Name</h6>
                            <small class="text-muted">@cat.Products.Count items</small>
                        </div>
                    </div>
                </a>
            </div>
        }
    </div>
</section>

<!-- Featured Products -->
<section class="container mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">Featured Products</h2>
        <a asp-controller="Products" asp-action="Index" class="text-warning text-decoration-none">View All <i class="fas fa-arrow-right ms-1"></i></a>
    </div>
    <div class="row g-4">
        @foreach (var product in Model.FeaturedProducts)
        {
            <div class="col-sm-6 col-md-4 col-lg-3">
                <div class="card h-100 border-0 shadow-sm product-card hover-lift">
                    @if (product.OriginalPrice.HasValue)
                    {
                        <span class="badge bg-danger position-absolute m-2">SALE</span>
                    }
                    <div class="product-img-wrap bg-light d-flex align-items-center justify-content-center" style="height:200px;">
                        <i class="fas fa-image fa-3x text-muted"></i>
                    </div>
                    <div class="card-body">
                        <small class="text-muted">@product.Category?.Name</small>
                        <h6 class="card-title fw-bold mt-1 mb-2">
                            <a asp-controller="Products" asp-action="Details" asp-route-id="@product.Id" class="text-dark text-decoration-none stretched-link">@product.Name</a>
                        </h6>
                        <div class="d-flex align-items-center justify-content-between">
                            <div>
                                <span class="fw-bold text-warning fs-5">$@product.Price.ToString("F2")</span>
                                @if (product.OriginalPrice.HasValue)
                                {
                                    <small class="text-muted text-decoration-line-through ms-1">$@product.OriginalPrice.Value.ToString("F2")</small>
                                }
                            </div>
                            <span class="badge @(product.StockQuantity > 0 ? "bg-success-subtle text-success" : "bg-danger-subtle text-danger")">
                                @(product.StockQuantity > 0 ? "In Stock" : "Out")
                            </span>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</section>

<!-- Promo Banner -->
<section class="container mb-5">
    <div class="bg-warning rounded-4 p-5 text-center">
        <h2 class="fw-bold text-dark">Free Shipping on Orders Over $50!</h2>
        <p class="text-dark opacity-75 mb-4">Use code FREESHIP at checkout. Limited time offer.</p>
        <a asp-controller="Products" asp-action="Index" class="btn btn-dark btn-lg px-5">Shop Now <i class="fas fa-arrow-right ms-2"></i></a>
    </div>
</section>

<!-- New Arrivals -->
<section class="container mb-5">
    <h2 class="fw-bold mb-4">New Arrivals</h2>
    <div class="row g-4">
        @foreach (var product in Model.NewArrivals.Take(4))
        {
            <div class="col-sm-6 col-md-3">
                <div class="card border-0 shadow-sm hover-lift">
                    <span class="badge bg-info position-absolute m-2">NEW</span>
                    <div class="bg-light d-flex align-items-center justify-content-center" style="height:160px;">
                        <i class="fas fa-box-open fa-2x text-muted"></i>
                    </div>
                    <div class="card-body">
                        <h6 class="card-title">
                            <a asp-controller="Products" asp-action="Details" asp-route-id="@product.Id" class="text-dark text-decoration-none stretched-link">@product.Name</a>
                        </h6>
                        <span class="fw-bold text-warning">$@product.Price.ToString("F2")</span>
                    </div>
                </div>
            </div>
        }
    </div>
</section>
