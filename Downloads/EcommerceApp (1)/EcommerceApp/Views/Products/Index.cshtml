@model EcommerceApp.Models.ProductListViewModel
@{
    ViewData["Title"] = "Shop All Products";
}

<div class="container py-4">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li class="breadcrumb-item active">Shop</li>
        </ol>
    </nav>

    <div class="row g-4">
        <!-- Sidebar Filters -->
        <div class="col-lg-3">
            <div class="card border-0 shadow-sm sticky-top" style="top: 80px;">
                <div class="card-body">
                    <h5 class="fw-bold mb-3">Filters</h5>
                    <form method="get">
                        <input type="hidden" name="search" value="@Model.SearchTerm" />
                        <input type="hidden" name="sortBy" value="@Model.SortBy" />

                        <h6 class="text-muted fw-bold mb-2">CATEGORIES</h6>
                        <div class="mb-3">
                            <div class="form-check mb-1">
                                <input class="form-check-input" type="radio" name="categoryId" value="" id="catAll" @(Model.CategoryId == null ? "checked" : "") onchange="this.form.submit()" />
                                <label class="form-check-label" for="catAll">All Categories</label>
                            </div>
                            @foreach (var cat in Model.Categories)
                            {
                                <div class="form-check mb-1">
                                    <input class="form-check-input" type="radio" name="categoryId" value="@cat.Id" id="cat@(cat.Id)"
                                           @(Model.CategoryId == cat.Id ? "checked" : "") onchange="this.form.submit()" />
                                    <label class="form-check-label" for="cat@(cat.Id)">@cat.Name <small class="text-muted">(@cat.Products.Count)</small></label>
                                </div>
                            }
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- Product Grid -->
        <div class="col-lg-9">
            <!-- Toolbar -->
            <div class="d-flex align-items-center justify-content-between mb-4">
                <div>
                    @if (!string.IsNullOrEmpty(Model.SearchTerm))
                    {
                        <span>Results for "<strong>@Model.SearchTerm</strong>"</span>
                    }
                    <small class="text-muted">@Model.TotalProducts products found</small>
                </div>
                <form method="get" class="d-flex align-items-center gap-2">
                    <input type="hidden" name="search" value="@Model.SearchTerm" />
                    <input type="hidden" name="categoryId" value="@Model.CategoryId" />
                    <label class="text-muted small mb-0">Sort:</label>
                    <select name="sortBy" class="form-select form-select-sm w-auto" onchange="this.form.submit()">
                        <option value="name" @(Model.SortBy == "name" ? "selected" : "")>Name</option>
                        <option value="price_asc" @(Model.SortBy == "price_asc" ? "selected" : "")>Price: Low to High</option>
                        <option value="price_desc" @(Model.SortBy == "price_desc" ? "selected" : "")>Price: High to Low</option>
                        <option value="newest" @(Model.SortBy == "newest" ? "selected" : "")>Newest</option>
                    </select>
                </form>
            </div>

            <!-- Products -->
            <div class="row g-4">
                @foreach (var product in Model.Products)
                {
                    <div class="col-sm-6 col-xl-4">
                        <div class="card h-100 border-0 shadow-sm product-card hover-lift">
                            @if (product.OriginalPrice.HasValue)
                            {
                                <span class="badge bg-danger position-absolute m-2 z-1">
                                    -@Math.Round((1 - product.Price / product.OriginalPrice.Value) * 100)%
                                </span>
                            }
                            <div class="bg-light d-flex align-items-center justify-content-center" style="height:200px;">
                                <i class="fas fa-image fa-3x text-muted"></i>
                            </div>
                            <div class="card-body d-flex flex-column">
                                <small class="text-muted">@product.Category?.Name</small>
                                <h6 class="card-title fw-bold mt-1 mb-2 flex-grow-1">@product.Name</h6>
                                <p class="text-muted small text-truncate">@product.Description</p>
                                <div class="d-flex align-items-center justify-content-between mt-2">
                                    <div>
                                        <span class="fw-bold text-warning fs-5">$@product.Price.ToString("F2")</span>
                                        @if (product.OriginalPrice.HasValue)
                                        {
                                            <small class="text-muted text-decoration-line-through ms-1">$@product.OriginalPrice.Value.ToString("F2")</small>
                                        }
                                    </div>
                                </div>
                                <div class="mt-3 d-flex gap-2">
                                    <a asp-controller="Products" asp-action="Details" asp-route-id="@product.Id" class="btn btn-outline-dark btn-sm flex-grow-1">
                                        <i class="fas fa-eye me-1"></i>Details
                                    </a>
                                    @if (product.StockQuantity > 0)
                                    {
                                        <form asp-controller="Cart" asp-action="AddToCart" method="post" class="flex-grow-1">
                                            <input type="hidden" name="productId" value="@product.Id" />
                                            <button type="submit" class="btn btn-warning btn-sm w-100">
                                                <i class="fas fa-cart-plus me-1"></i>Add
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <button class="btn btn-secondary btn-sm flex-grow-1" disabled>Out of Stock</button>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- Pagination -->
            @if (Model.TotalPages > 1)
            {
                <nav class="mt-5 d-flex justify-content-center">
                    <ul class="pagination">
                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                <a class="page-link" asp-action="Index"
                                   asp-route-search="@Model.SearchTerm"
                                   asp-route-categoryId="@Model.CategoryId"
                                   asp-route-sortBy="@Model.SortBy"
                                   asp-route-page="@i">@i</a>
                            </li>
                        }
                    </ul>
                </nav>
            }
        </div>
    </div>
</div>
